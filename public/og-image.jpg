<svg width="1200" height="630" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="bgGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1a472a;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#2d5a3d;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Background -->
  <rect width="1200" height="630" fill="url(#bgGradient)"/>
  
  <!-- Decorative clover pattern -->
  <g opacity="0.1">
    <circle cx="100" cy="100" r="40" fill="#ffffff"/>
    <circle cx="140" cy="100" r="40" fill="#ffffff"/>
    <circle cx="120" cy="140" r="40" fill="#ffffff"/>
    <circle cx="120" cy="60" r="40" fill="#ffffff"/>
    <circle cx="120" cy="100" r="15" fill="#ffffff"/>
  </g>
  
  <g opacity="0.1">
    <circle cx="1100" cy="530" r="40" fill="#ffffff"/>
    <circle cx="1140" cy="530" r="40" fill="#ffffff"/>
    <circle cx="1120" cy="570" r="40" fill="#ffffff"/>
    <circle cx="1120" cy="490" r="40" fill="#ffffff"/>
    <circle cx="1120" cy="530" r="15" fill="#ffffff"/>
  </g>
  
  <!-- Main content -->
  <text x="600" y="250" font-family="Arial, sans-serif" font-size="64" font-weight="bold" fill="#ffffff" text-anchor="middle">
    Five Clover Hotels Group
  </text>
  
  <text x="600" y="320" font-family="Arial, sans-serif" font-size="32" fill="#d4af37" text-anchor="middle">
    Premium Hotels in Lagos, Nigeria
  </text>
  
  <text x="600" y="400" font-family="Arial, sans-serif" font-size="24" fill="#ffffff" text-anchor="middle" opacity="0.9">
    Five Clover • Caritas Inn • Ring Ruby • The Cordis
  </text>
  
  <!-- Bottom accent line -->
  <rect x="400" y="480" width="400" height="4" fill="#d4af37"/>
  
  <text x="600" y="540" font-family="Arial, sans-serif" font-size="20" fill="#ffffff" text-anchor="middle" opacity="0.8">
    Experience Luxury & Comfort
  </text>
</svg>
