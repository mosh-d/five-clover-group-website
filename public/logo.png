<svg width="512" height="512" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="logoGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1a472a;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#2d5a3d;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Background circle -->
  <circle cx="256" cy="256" r="240" fill="url(#logoGradient)"/>
  
  <!-- Five clover leaves arranged in a pattern -->
  <!-- Center clover -->
  <g transform="translate(256, 256)">
    <!-- Top leaf -->
    <ellipse cx="0" cy="-50" rx="25" ry="35" fill="#d4af37"/>
    <!-- Right leaf -->
    <ellipse cx="50" cy="0" rx="35" ry="25" fill="#d4af37"/>
    <!-- Bottom leaf -->
    <ellipse cx="0" cy="50" rx="25" ry="35" fill="#d4af37"/>
    <!-- Left leaf -->
    <ellipse cx="-50" cy="0" rx="35" ry="25" fill="#d4af37"/>
    <!-- Center leaf -->
    <ellipse cx="0" cy="0" rx="30" ry="30" fill="#d4af37"/>
    
    <!-- Stem -->
    <rect x="-4" y="50" width="8" height="40" fill="#d4af37"/>
  </g>
  
  <!-- Text -->
  <text x="256" y="440" font-family="Arial, sans-serif" font-size="48" font-weight="bold" fill="#ffffff" text-anchor="middle">
    FIVE CLOVER
  </text>
  
  <text x="256" y="475" font-family="Arial, sans-serif" font-size="24" fill="#d4af37" text-anchor="middle">
    HOTELS GROUP
  </text>
</svg>
